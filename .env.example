# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
# Optional: set this to your server (guild) ID for instant slash command registration.
# Without it, commands are registered globally and may take up to 1 hour to appear.
# Right-click your server icon in Discord → "Copy Server ID" (requires Developer Mode).
# Enable Developer Mode: User Settings → Advanced → Developer Mode
DISCORD_GUILD_ID=

# Database Configuration
DATABASE_PATH=./data/research-agent.db

# Logging Configuration
LOG_LEVEL=info
LOG_DIR=./logs

# OpenAlex API Configuration
OPENALEX_API_URL=https://api.openalex.org
OPENALEX_EMAIL=your_email@example.com
OPENALEX_MAX_RESULTS=10

# Paper Fetching Configuration
FETCH_INTERVAL_HOURS=24
DEFAULT_TOPICS=artificial intelligence,machine learning,natural language processing
MIN_CITATION_COUNT=10

# GitHub Copilot SDK Configuration
GITHUB_TOKEN=your_github_token_here
# Available models (GitHub Copilot):
#   gpt-4.1          — Latest GPT-4.1, best quality (default)
#   gpt-4o           — GPT-4o, fast + strong multimodal reasoning
#   gpt-4o-mini      — GPT-4o Mini, fastest + cheapest
#   o3-mini          — OpenAI o3-mini, strong at reasoning tasks
#   claude-sonnet-4-5 — Anthropic Claude Sonnet 4.5
COPILOT_MODEL=gpt-4.1

# Environment
NODE_ENV=development
