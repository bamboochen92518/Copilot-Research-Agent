{
  "name": "copilot-research-agent",
  "version": "1.0.0",
  "description": "An intelligent Discord bot that automatically fetches, summarizes, and organizes academic papers from OpenAlex using GitHub Copilot SDK.",
  "main": "dist/bot.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/bot.js",
    "dev": "tsx src/bot.ts",
    "watch": "tsc -w",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "demo:fetcher": "ts-node scripts/demo-fetcher.ts",
    "commands:register": "tsx scripts/register-commands.ts",
    "demo:discord": "ts-node scripts/demo-discord.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bamboochen92518/Copilot-Research-Agent.git"
  },
  "keywords": [
    "discord",
    "bot",
    "openalex",
    "research",
    "papers",
    "academic",
    "copilot",
    "ai"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/bamboochen92518/Copilot-Research-Agent/issues"
  },
  "homepage": "https://github.com/bamboochen92518/Copilot-Research-Agent#readme",
  "dependencies": {
    "@github/copilot-sdk": "^0.2.0",
    "axios": "^1.14.0",
    "better-sqlite3": "^12.8.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "pdf-parse": "^2.4.5",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/pdf-parse": "^1.1.5",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
